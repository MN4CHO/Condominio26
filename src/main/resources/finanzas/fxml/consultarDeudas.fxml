<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="fis.dsw.sgc.finanzas.controller.ConsultarDeudasController"
      alignment="TOP_CENTER"
      maxHeight="1.7976931348623157E308"
      maxWidth="1.7976931348623157E308"
      prefHeight="600.0"
      prefWidth="900.0"
      spacing="16.0"
      styleClass="module-content"
      stylesheets="@../css/finanzasStyles.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1">

    <padding>
        <Insets bottom="32.0" left="32.0" right="32.0" top="32.0"/>
    </padding>

    <children>
        <Label styleClass="module-title" text="Consultar deudas"/>
        <Label styleClass="module-subtitle"
               text="Consulte las deudas de un residente por número de cédula (estados PENDIENTE, EN PROCESO o MORA)."/>

        <VBox maxWidth="960.0"
              maxHeight="1.7976931348623157E308"
              spacing="16.0"
              VBox.vgrow="ALWAYS">
            <children>
                <VBox spacing="12.0" styleClass="module-card"
                      maxWidth="1.7976931348623157E308">
                    <padding>
                        <Insets bottom="20.0" left="24.0" right="24.0" top="20.0"/>
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Label styleClass="form-label" text="Cédula"/>
                                <TextField fx:id="txtCedula"
                                           prefWidth="320.0"
                                           maxWidth="400.0"
                                           promptText="Número de cédula del residente"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="btnConsultar"
                                        mnemonicParsing="false"
                                        onAction="#consultar"
                                        styleClass="primary-button"
                                        text="Consultar"/>
                                <Button fx:id="btnLimpiar"
                                        mnemonicParsing="false"
                                        onAction="#limpiar"
                                        styleClass="secondary-button"
                                        text="Limpiar"/>
                            </children>
                        </HBox>
                        <Label fx:id="lblMensaje" styleClass="message-label, message-info" text=""/>
                    </children>
                </VBox>

                <VBox maxHeight="1.7976931348623157E308"
                      maxWidth="1.7976931348623157E308"
                      spacing="8.0"
                      styleClass="table-card"
                      VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
                    </padding>
                    <children>
                        <Label styleClass="module-section-title" text="Resultados"/>
                        <TableView fx:id="tablaDeudas"
                                   maxHeight="1.7976931348623157E308"
                                   maxWidth="1.7976931348623157E308"
                                   VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colMotivo" prefWidth="140.0" text="Motivo"/>
                                <TableColumn fx:id="colValor" prefWidth="100.0" text="Valor"/>
                                <TableColumn fx:id="colFechaMax" prefWidth="150.0" text="Fecha máx. pago"/>
                                <TableColumn fx:id="colEstado" prefWidth="120.0" text="Estado"/>
                                <TableColumn fx:id="colDescripcion" prefWidth="280.0" text="Descripción"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>
